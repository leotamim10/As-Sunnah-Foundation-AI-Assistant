# ── Copy to .env and fill in. NEVER commit real keys — only this .example file. ──

# ── Understanding: a multi-model failover chain. Each model that has a key below joins the chain;
#    on a rate-limit (429) the gateway auto-switches to the next. Set any subset — at least one. ──

# Default order when MODEL_CHAIN is unset: this provider goes first, then the rest.
UNDERSTANDING_PROVIDER=gemini
# Optional explicit order (comma-separated ids): gemini-1,gemini-2,groq-llama,hf-qwen3,openrouter-qwen
MODEL_CHAIN=

# --- Gemini (multimodal + vision, best Bengali) --- https://aistudio.google.com/apikey
GEMINI_API_KEY=
# A SECOND Gemini key (different Google project/account) adds daily quota; joins the chain as gemini-2.
GEMINI_API_KEY_2=
# Model must accept AUDIO input. gemini-2.5-flash works on the free tier; confirm the current string.
GEMINI_MODEL=gemini-2.5-flash

# --- Hugging Face (Qwen3 LLM + Whisper STT; text-only) --- https://huggingface.co/settings/tokens
# HF_TOKEN also powers the shared Whisper STT used by ALL text providers (groq/openrouter) for voice.
HF_TOKEN=
# whisper-large-v3 (provider auto → fal-ai) returns correct BENGALI script + honors the language hint.
# The free hf-inference whisper-large-v3-turbo mis-transcribes Bengali into Hindi, so it's only a
# fallback. Keep comments on their own line — docker-compose env_file folds a trailing `# ...` in.
HF_STT_MODEL=openai/whisper-large-v3
HF_LLM_MODEL=Qwen/Qwen3-32B

# --- Groq (very fast, text-only) --- https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (many models via one key, text-only) --- https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# --- TTS voice (used by both the Edge and Azure paths) ---
# bn-BD-NabanitaNeural (F) or bn-BD-PradeepNeural (M). MUST be bn-BD, never bn-IN (Kolkata).
TTS_VOICE=bn-BD-NabanitaNeural

# Default TTS path is Edge (Microsoft Edge read-aloud) — SAME bn-BD voices, NO key / subscription / card.
# Nothing to set for it. Leave the Azure keys below BLANK to run fully card-free.

# --- TTS fallback (Azure Neural, OPTIONAL) ---
# Fill these only if you want Azure as a paid fallback behind Edge. Portal → Speech resource → Keys and Endpoint.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- Wiring ---
# Where the Python WS server reaches the Node gateway. In docker-compose this is http://gateway:8787.
GATEWAY_URL=http://localhost:8787
# Python WS server port (the browser connects here).
PORT=8000
