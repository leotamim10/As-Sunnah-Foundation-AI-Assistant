# ai-gateway/.env  —  copy to .env, never commit real keys
PORT=8787

# Which understanding path to use:  gemini | hf
UNDERSTANDING_PROVIDER=gemini

# --- Gemini path (default): one multimodal call, best Bengali, has vision ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash        # confirm current model string; MUST support audio input

# --- HF path (alternative): Whisper STT -> hosted Bengali LLM. Token only, no card ---
HF_TOKEN=
HF_STT_MODEL=openai/whisper-large-v3 # 99 languages incl. Bengali
HF_LLM_MODEL=Qwen/Qwen3-32B          # add ":cerebras" / ":groq" to route via a fast provider

# --- TTS: Edge bn-BD (card-free, native Bangladeshi voices) ---
TTS_VOICE=bn-BD-NabanitaNeural       # or bn-BD-PradeepNeural.  Do NOT use bn-IN (Kolkata).

# --- Optional: Azure TTS (only if you later get a card; same bn-BD voices, production-grade) ---
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
