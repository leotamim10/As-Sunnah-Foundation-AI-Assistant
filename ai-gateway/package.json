{
  "name": "parlor-ai-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node/TS gateway bridging parlor's FastAPI WS server to free-tier APIs: Gemini (audio+image -> transcription+reply) + Azure bn-BD TTS.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "tts:sample": "node --import tsx scripts/tts-sample.ts",
    "knowledge:build": "node --import tsx knowledge/build.ts",
    "knowledge:query": "node --import tsx knowledge/query.ts",
    "knowledge:eval": "node --import tsx knowledge/eval.ts"
  },
  "dependencies": {
    "@google/genai": "^1.9.0",
    "@travisvn/edge-tts": "^1.0.2",
    "@xenova/transformers": "^2.17.2",
    "fastify": "^5.2.0",
    "ffmpeg-static": "^5.3.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.42.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
