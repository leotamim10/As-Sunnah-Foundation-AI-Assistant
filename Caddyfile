# Local HTTPS for camera/mic testing (secure context). Caddy terminates TLS with a self-signed
# "internal" cert and reverse-proxies to the web server, including WebSocket upgrades for /ws.
# Hostnames are explicit so `tls internal` pre-issues certs for the names we actually use.
localhost:8443, 127.0.0.1:8443, host.docker.internal:8443 {
	tls internal
	reverse_proxy web:8000
}
