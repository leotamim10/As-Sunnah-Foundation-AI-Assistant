# Secrets — never commit real keys. Only .env is real here; .env.example is the tracked template.
# NB: avoid a `.env.*` glob — it matches `.env.example`, and glob-based cleaners ignore git's `!` negation
# and can delete the template (this happened once). List real env files explicitly instead.
.env
.env.local

# Node
node_modules/
dist/
*.log

# Generated TTS verification samples
ai-gateway/scripts/samples/

# Generated knowledge base (rebuild with `npm run knowledge:build`)
ai-gateway/knowledge/knowledge.json

# Embedding-model cache (baked into the Docker image, never committed)
ai-gateway/models/
**/.cache/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
